Algoritmo Colores
	Definir n Como Entero
	Definir datos como cadena
	dimension datos[8]
	datos[1]= "Cafe"
	datos[2]= "Morado"
	datos[3]="Corinto"
	datos[4]="Rojo"
	datos[5]="Verde" 
	datos[6]="Verde Oscuro"
	datos[7]="Violeta"
	datos[8]="Negro"
	
	Escribir Sin Saltar "Elige un numero del 1 al 8:"
	Leer n
	Escribir "El color de esa casilla es, " , datos[n]
	
	
FinAlgoritmo
